# Environment and secrets
.env
keys/
*.pem
*.key
*.egg-info/

# Generated output
output/
scale-test/generated/
scale-test/reports/

# Validation run artifacts. Runs are reproducible from configuration and seed,
# are large, and tracking them made the development and execution hosts
# diverge. Anything that must survive cleanup belongs in artifacts/evidence/.
artifacts/runs/
artifacts/policy-deployments.jsonl
artifacts/test-documents/
artifacts/repro-issue-003.nol

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Editors and OS
.vscode/
.DS_Store
**/.DS_Store

# Benchmark harness build + run artifacts (demos/benchmark). Source and corpus
# are tracked; the Go binary, build cache, per-mode result files, resource
# metrics, and the generated HTML report are regenerated by run_all.sh.
demos/benchmark/**/go/benchmark_runner
demos/benchmark/**/.gocache/
demos/benchmark/**/results/*.jsonl
demos/benchmark/**/results/*.csv
demos/benchmark/**/results/*.json
demos/benchmark/**/results/*.txt
demos/benchmark/**/report/report.html
demos/benchmark/**/report/report_data.json
# The on-brand report is generated from run.json by make-report.py (run.json,
# make-report.py, and brand/ are tracked; the rendered HTML is not).
demos/benchmark/pre-index-report.html
demos/benchmark/datapoint2/pre-post-report.html

# PDF renders of docs (yzane.markdown-pdf), generated on demand to share with
# engineering. Regenerated when needed, so not versioned. The extension is
# configured (in .vscode/settings.json) to write them to handoff/.
*.pdf
handoff/