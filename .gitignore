# Environment and secrets
.env
keys/
*.pem
*.key
*.egg-info/

# Generated output
output/
scale-test/generated/
scale-test/reports/

# Validation run artifacts. Runs are reproducible from configuration and seed,
# are large, and tracking them made the development and execution hosts
# diverge. Anything that must survive cleanup belongs in artifacts/evidence/.
artifacts/runs/
artifacts/policy-deployments.jsonl
artifacts/test-documents/
artifacts/repro-issue-003.nol

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Editors and OS
.vscode/
.DS_Store
**/.DS_Store

# PDF renders of docs (yzane.markdown-pdf), generated on demand to share with
# engineering. Regenerated when needed, so not versioned. The extension is
# configured (in .vscode/settings.json) to write them to handoff/.
*.pdf
handoff/