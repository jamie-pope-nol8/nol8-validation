THEMIS_POLICY_ENDPOINT="https://themis.sales.nol8.cloud:8444/policy"
AERGIA_POLICY_ENDPOINT="https://aergia.sales.nol8.cloud:8444/policy"

THEMIS_PROCESS_ENDPOINT="https://tenant001-v1demo.nol8.net:443/v1/process"

# The policy control plane presents a self-signed certificate named after an
# internal address (CN=ip-172-31-40-100), so TLS verification fails against
# themis.sales.nol8.cloud. Setting this is required to deploy policies today.
#
# It is deliberately explicit rather than hardcoded: this call carries the
# bearer token and the complete ruleset. The processing endpoint has a valid
# Amazon-issued certificate and needs no such exception.
#
# Remove this once the control plane presents a certificate matching its name.
# See limitation 7 in docs/product/themis-product-limitations.md.
THEMIS_ALLOW_INSECURE_TLS=1
