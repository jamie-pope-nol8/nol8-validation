{
  "//": "Personal sandbox: Bash allowed broadly, narrowed by deny. .env is gitignored; EC2 is disposable. Revisit if either stops being true. NOTE: project allow rules only take effect after the VS Code workspace-trust dialog is accepted.",
  "permissions": {
    "allow": [
      "Bash",
      "Read(//private/tmp/**)",
      "Read(//Users/jamiepope/.claude/**)",
      "Write(//private/tmp/**)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(doas:*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(mkfs:*)",
      "Bash(dd:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(halt:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard origin/*)",
      "Bash(git clean -fdx:*)",
      "Bash(chmod -R 777:*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Read(./.env)",
      "Read(//Users/jamiepope/.ssh/id_*)",
      "Read(//Users/jamiepope/.aws/credentials)"
    ]
  }
}
