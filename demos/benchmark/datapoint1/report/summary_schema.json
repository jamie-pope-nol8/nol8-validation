{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BenchmarkAiSummary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "headline",
    "executive_summary",
    "key_findings",
    "caveats",
    "mode_notes"
  ],
  "properties": {
    "headline": {
      "type": "string",
      "minLength": 1
    },
    "executive_summary": {
      "type": "string",
      "minLength": 1
    },
    "key_findings": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "caveats": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "mode_notes": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
